# Copy to .env for local `vercel dev` use. Never commit the real .env file.

ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to claude-sonnet-5 if omitted
# ANTHROPIC_MODEL=claude-sonnet-5

# These are auto-injected once you connect an Upstash Redis database via
# the Vercel Marketplace (Storage tab) — you shouldn't need to set them by
# hand except for local testing. Either naming works; the app checks both.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
